# GUI
# =========================================================
def run_all():
    folder = os.path.dirname(os.path.abspath(__file__))
    today  = datetime.today().strftime("%Y-%m-%d")
    output_path = os.path.join(folder, f"PantaloonsFashion_Stores_{today}.xlsx")

    print("=" * 70)
    print("[INFO] STARTING Pantaloons STORE SCRAPER (Selenium)")
    print("=" * 70)

    try:
        scrape_pantaloons_stores(output_path)
        print("=" * 70)
        print("[INFO] DONE")
        print("=" * 70)
        messagebox.showinfo("Done", f"Saved to:\n{output_path}")
    except Exception as e:
        print(f"[ERROR] {e}")
        messagebox.showerror("Error", str(e))


def run_gui():
    root = tk.Tk()
    root.title("Pantaloons Store Scraper")
    root.geometry("430x240")
    root.resizable(False, False)

    tk.Label(root, text="Pantaloons Store Scraper",
             font=("Segoe UI", 14, "bold")).pack(pady=20)
    tk.Label(root, text="(Opens Chrome — keep window open while running)",
             font=("Segoe UI", 9), fg="gray").pack()
    tk.Button(root, text="Run Scraper", width=18, height=2,
              font=("Segoe UI", 12, "bold"), command=run_all).pack(pady=20)

    root.mainloop()


if __name__ == "__main__":
    run_gui()
