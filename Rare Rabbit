import os
import re
import time
import random
from datetime import datetime
import requests
import pandas as pd
from bs4 import BeautifulSoup
import tkinter as tk
from tkinter import messagebox

# =========================================================
# CONFIG
# =========================================================
_UA = "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36"
BASE_URL = "https://stores-rarerabbit.thehouseofrare.com/"

HEADERS = {
    "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,image/avif,image/webp,*/*;q=0.8",
    "Accept-Language": "en-US,en;q=0.5",
    "Connection": "keep-alive",
    "User-Agent": _UA,
}

PINCODE_RE = re.compile(r"\b(\d{6})\b")


# =========================================================
# HELPERS
# =========================================================
def make_session():
    return requests.Session()


def _clean(text):
    return " ".join((text or "").replace("\n", " ").replace("\r", " ").split())


def _get(session, url, params=None, retries=3, base_sleep=1.0):
    for attempt in range(1, retries + 1):
        try:
            r = session.get(url, params=params, headers=HEADERS, timeout=20)
            if r.status_code == 200:
                return r
            if r.status_code in (429, 503, 502):
                time.sleep(base_sleep * (2 ** (attempt - 1)) + random.uniform(0, 0.5))
                continue
            return r
        except requests.RequestException:
            time.sleep(base_sleep * (2 ** (attempt - 1)))
    return None


# =========================================================
# PARSER
# =========================================================
def _parse_card(card):
    lat = _clean(card.find("input", class_="outlet-latitude")["value"]) if card.find("input", class_="outlet-latitude") else ""
    lng = _clean(card.find("input", class_="outlet-longitude")["value"]) if card.find("input", class_="outlet-longitude") else ""

    # Store name, city, state from the outlet-name anchor's data attributes
    name_a     = card.select_one("li.outlet-name a")
    store_name = _clean(name_a.get_text()) if name_a else "Rare Rabbit"
    city       = _clean(name_a.get("data-track-event-city", "")).title() if name_a else ""
    state_val  = _clean(name_a.get("data-track-event-state", "")).title() if name_a else ""

    # Address spans inside outlet-address
    addr_div = card.select_one("li.outlet-address .info-text")
    addr = _clean(addr_div.get_text(separator=" ")) if addr_div else ""

    # Phone from tel: link
    phone_a = card.select_one("li.outlet-phone a[href^='tel:']")
    phone   = _clean(phone_a.get_text()) if phone_a else ""

    # Store link from the Website button
    website_a  = card.select_one("a.btn-website")
    store_link = _clean(website_a["href"]) if website_a and website_a.get("href") else ""

    pin_m   = PINCODE_RE.search(addr)
    pincode = pin_m.group(1) if pin_m else ""

    maps_url = f"https://www.google.com/maps?q={lat},{lng}" if lat and lng else ""

    return {
        "Store Name": store_name,
        "City":       city,
        "State":      state_val,
        "Address":    addr,
        "Pincode":    pincode,
        "Phone No":   phone,
        "Store Link": store_link,
        "Maps URL":   maps_url,
    }


# =========================================================
# SCRAPER
# =========================================================
def scrape_all(output_path, max_pages=35):
    session = make_session()
    rows = []
    empty_pages_seen = 0

    print("[INFO] Fetching Rare Rabbit stores...")

    for page in range(1, max_pages + 1):
        r = _get(session, BASE_URL, params={"page": page})

        if r is None:
            print(f"[WARN] Failed to fetch page {page}")
            empty_pages_seen += 1
            if empty_pages_seen >= 3:
                print("[INFO] Too many failed pages. Stopping.")
                break
            continue

        soup  = BeautifulSoup(r.text, "html.parser")
        cards = soup.find_all("div", class_="store-info-box")

        if not cards:
            print(f"[INFO] No store cards on page {page}. Done.")
            break

        empty_pages_seen = 0
        print(f"[INFO] Page {page}: {len(cards)} stores")

        for card in cards:
            rows.append(_parse_card(card))

        time.sleep(0.5 + random.uniform(0, 0.4))

    df = pd.DataFrame(rows)
    df = df.drop_duplicates(subset=["Store Link"])

    col_order = ["Store Name", "City", "State", "Address", "Pincode", "Phone No", "Store Link", "Maps URL"]
    df = df.reindex(columns=col_order)

    df.to_excel(output_path, index=False)
    print(f"[INFO] Saved {len(df)} stores to {output_path}")
    return df


# =========================================================
# GUI
# =========================================================
def run_all():
    folder = os.path.dirname(os.path.abspath(__file__))
    today  = datetime.today().strftime("%Y-%m-%d")
    output_path = os.path.join(folder, f"RareRabbit_Stores_{today}.xlsx")

    print("=" * 70)
    print("[INFO] STARTING RARE RABBIT SCRAPER")
    print("=" * 70)

    scrape_all(output_path)

    print("=" * 70)
    print("[INFO] FILE SAVED SUCCESSFULLY")
    print("=" * 70)

    messagebox.showinfo("Success", f"Saved to:\n{output_path}")


def run_gui():
    root = tk.Tk()
    root.title("Rare Rabbit Scraper")
    root.geometry("430x220")
    root.resizable(False, False)

    tk.Label(
        root,
        text="Rare Rabbit Store Scraper",
        font=("Segoe UI", 14, "bold")
    ).pack(pady=20)

    tk.Button(
        root,
        text="Run",
        width=18,
        height=2,
        font=("Segoe UI", 12, "bold"),
        command=run_all
    ).pack(pady=20)

    root.mainloop()


if __name__ == "__main__":
    run_gui()
