def _search_term(city):
    """Simplify complex city names before typing into the search box."""
    city = re.sub(r'\s*\([^)]*\)', '', city).strip()   # remove "(town)" etc.
    if '–' in city or '—' in city:
        city = re.split(r'[–—]', city)[0].strip()       # "Hubli–Dharwad" → "Hubli"
    if ' & ' in city:
        city = city.split(' & ')[0].strip()              # "Sangli & Kupwad" → "Sangli"
    return city


