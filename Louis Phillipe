def _get_store_count(driver):
    try:
        m = re.search(r'(\d+)\s*Stores?\s*Found', driver.find_element(By.TAG_NAME, "body").text, re.I)
        return int(m.group(1)) if m else 0
    except Exception:
        return 0


# JS: find the City/Area input by scanning all inputs for a city/area placeholder
_JS_FIND_INPUT = """
var inputs = document.querySelectorAll('input');
for (var i = 0; i < inputs.length; i++) {
    var p = (inputs[i].placeholder || '').toLowerCase();
    if (p.includes('city') || p.includes('area') || p.includes('address')) {
        return inputs[i];
    }
}
return null;
"""

# JS: click the first visible dropdown option that contains city text
_JS_CLICK_FIRST_OPTION = """
var city = arguments[0].toLowerCase();
var selectors = ['li', '[role="option"]', '[role="listitem"]',
                 '[class*="suggestion"]', '[class*="option"]', '[class*="item"]'];
for (var si = 0; si < selectors.length; si++) {
    var els = document.querySelectorAll(selectors[si]);
    for (var i = 0; i < els.length; i++) {
        var el = els[i];
        if (el.offsetWidth === 0 && el.offsetHeight === 0) continue;
        var txt = (el.innerText || '').trim();
        if (txt && txt.toLowerCase().includes(city)) {
            el.click();
            return txt;
        }
    }
}
return null;
"""

# JS: scrape store cards — finds the list container where multiple siblings
# all have card-sized text (letters + digits). Does NOT require AM/PM.
_JS_SCRAPE_CARDS = """
var cards = [];
var seenParents = new WeakSet();

var allEls = document.querySelectorAll('*');
for (var i = 0; i < allEls.length; i++) {
    var el = allEls[i];
    var t = (el.innerText || '').trim();
    // Card-sized element with both letters (name/address) and digits (pincode/phone/number)
    if (t.length < 40 || t.length > 800) continue;
    if (el.children.length > 25) continue;
    if (!/\d/.test(t) || !/[A-Za-z]{3,}/.test(t)) continue;

    var parent = el.parentElement;
    if (!parent || parent === document.body) continue;
    if (seenParents.has(parent)) continue;

    // Count siblings that also look like store cards
    var sibTexts = [];
    for (var j = 0; j < parent.children.length; j++) {
        var sib = parent.children[j];
        var st = (sib.innerText || '').trim();
        if (st.length >= 40 && st.length <= 800 &&
            /\d/.test(st) && /[A-Za-z]{3,}/.test(st) &&
            sib.children.length <= 25) {
            sibTexts.push(st);
        }
    }

    // Only use this container if it has 3+ card-like children (real store list)
    if (sibTexts.length >= 3) {
        seenParents.add(parent);
        for (var k = 0; k < sibTexts.length; k++) {
            cards.push({ text: sibTexts[k], tag: 'CARD', cls: '' });
        }
        if (cards.length >= 60) break;
    }
}
return cards;
"""

# JS: get raw panel text for debug / fallback parsing
_JS_GET_PANEL_TEXT = """
var all = document.querySelectorAll('*');
for (var i = 0; i < all.length; i++) {
    var t = (all[i].innerText || '').trim();
    if (/^\d+\s*Stores?\s*Found/i.test(t) && all[i].children.length <= 5) {
        var p = all[i].parentElement;
        for (var d = 0; d < 10; d++) {
            if (!p || p === document.body) break;
            if (p.children.length >= 3) {
                return {
                    text: (p.innerText || '').substring(0, 4000),
                    html: p.innerHTML.substring(0, 3000),
                    kids: p.children.length
                };
            }
            p = p.parentElement;
        }
    }
}
return null;
"""


def _find_city_input(driver):
    """Find the City/Area input via JS (case-insensitive placeholder match)."""
    el = driver.execute_script(_JS_FIND_INPUT)
    if el is None:
        raise RuntimeError("City/Area input not found on page")
    return el


def _clear_and_type(driver, inp, city):
    """Clear the input and type the city name."""
    driver.execute_script("arguments[0].value = '';", inp)
    inp.click()
    time.sleep(0.2)
    inp.send_keys(Keys.CONTROL + "a")
    inp.send_keys(Keys.DELETE)
    time.sleep(0.1)
    inp.send_keys(city)
    time.sleep(2.5)


def _click_first_dropdown_option(driver, city="", timeout=6):
    """
    Physically move the mouse to the best .pac-item and click it using pynput.
    Falls back to keyboard navigation (Arrow Down + Return) if pynput is
    unavailable or screen-coordinate calculation fails.
    """
    try:
        from pynput.mouse import Button, Controller as MouseController
        _pynput = True
    except ImportError:
        _pynput = False

    city_lower = city.lower()
    first_word = re.split(r'[\s,\-\(]', city_lower)[0] if city_lower else ""

    # 1. Wait for .pac-item suggestions to appear
    deadline = time.time() + timeout
    visible_texts = []
    while time.time() < deadline:
        visible_texts = driver.execute_script("""
            var out = [];
            var items = document.querySelectorAll('.pac-item');
            for (var i = 0; i < items.length; i++) {
                var r = items[i].getBoundingClientRect();
                if (r.height > 0) out.push((items[i].innerText || '').trim());
            }
            return out;
        """) or []
        if visible_texts:
            break
        time.sleep(0.25)

    if not visible_texts:
        return None

    # 2. Best matching index
    best_idx = 0
    for i, txt in enumerate(visible_texts):
        if first_word and first_word in txt.lower():
            best_idx = i
            break

    # 3a. pynput: move mouse to exact screen coordinates and click
    if _pynput:
        coords = driver.execute_script("""
            var idx = arguments[0];
            var items = document.querySelectorAll('.pac-item');
            var visible = [];
            for (var i = 0; i < items.length; i++) {
                var r = items[i].getBoundingClientRect();
                if (r.height > 0) visible.push(items[i]);
            }
            if (idx >= visible.length) return null;
            var r = visible[idx].getBoundingClientRect();
            var chromeH = window.outerHeight - window.innerHeight;
            var chromeW = window.outerWidth - window.innerWidth;
            return {
                x: Math.round(window.screenX + chromeW / 2 + r.left + r.width / 2),
                y: Math.round(window.screenY + chromeH + r.top + r.height / 2)
            };
        """, best_idx)

        if coords:
            mouse = MouseController()
            mouse.position = (coords['x'], coords['y'])
            time.sleep(0.15)
            mouse.press(Button.left)
            time.sleep(0.05)
            mouse.release(Button.left)
            time.sleep(0.4)
            return visible_texts[best_idx]

    # 3b. Keyboard fallback: Arrow Down × N then Return
    inp = driver.execute_script("""
        var inputs = document.querySelectorAll('input');
        for (var i = 0; i < inputs.length; i++) {
            var p = (inputs[i].placeholder || '').toLowerCase();
            if (p.includes('city') || p.includes('area') || p.includes('address')) return inputs[i];
        }
        return null;
    """)
    if not inp:
        return None

    for _ in range(best_idx + 1):
        inp.send_keys(Keys.ARROW_DOWN)
        time.sleep(0.1)
    inp.send_keys(Keys.RETURN)
    time.sleep(0.4)
    return visible_texts[best_idx]


def _wait_for_stores(driver, timeout=6):
    deadline = time.time() + timeout
    while time.time() < deadline:
        if _get_store_count(driver) > 0:
            return True
        time.sleep(0.5)
    return False


def _parse_card(text, city_searched):
    lines = [l.strip() for l in text.split("\n") if l.strip()]
    name = ""
    address_parts = []
    phone = ""
    open_t = close_t = ""

    pin_m = re.search(r'\b(\d{6})\b', text)
    pincode = pin_m.group(1) if pin_m else ""

    for i, line in enumerate(lines):
        if re.search(r'\d{1,2}:\d{2}\s*(AM|PM)', line, re.I):
            parts = re.split(r'\s*[-–]\s*', line, maxsplit=1)
            open_t  = parts[0].strip()
            close_t = parts[1].strip() if len(parts) == 2 else ""
        elif re.search(r'(\+91[\s-]?)?\b\d{10}\b', line):
            digits = re.sub(r'\D', '', line)
            phone = digits[-10:] if len(digits) >= 10 else digits
        elif i == 0:
            name = line
        elif line.lower() not in ("express delivery", "alteration", "personal shopper"):
            address_parts.append(line)

    return {
        "Store Name":    name,
        "City Searched": city_searched,
        "Address":       ", ".join(address_parts),
        "Pincode":       pincode,
        "Phone":         phone,
        "Open Time":     open_t,
        "Close Time":    close_t,
    }


_debug_printed = [False]   # print panel debug once per run

def _scrape_visible_stores(driver, city_searched):
    if _get_store_count(driver) == 0:
        return []

    raw = driver.execute_script(_JS_SCRAPE_CARDS) or []

    # If JS found nothing, print the raw panel text ONCE so we can see the card format
    if not raw and not _debug_printed[0]:
        _debug_printed[0] = True
        panel = driver.execute_script(_JS_GET_PANEL_TEXT)
        if panel:
            print(f"\n[DEBUG] Panel has {panel['kids']} children.")
            print(f"[DEBUG PANEL TEXT]\n{panel['text'][:3000]}")
            print(f"[DEBUG PANEL HTML]\n{panel['html'][:2000]}")
        else:
            body = driver.find_element(By.TAG_NAME, "body").text
            print(f"\n[DEBUG BODY TEXT (first 3000)]\n{body[:3000]}")

    stores = []
    for card in raw:
        s = _parse_card(card["text"], city_searched)
        if s["Store Name"]:
            stores.append(s)
    return stores


def _save_partial(all_stores, output_path):
    if not all_stores:
        return
    df = pd.DataFrame(all_stores.values()).drop(columns=["City Searched"], errors="ignore")
    df = df.sort_values("Store Name").reset_index(drop=True)
    df.to_excel(output_path, index=False)
    print(f"  [partial save: {len(df)} stores -> {output_path}]")


# =========================================================
# MAIN SCRAPER
# =========================================================
def scrape_louis_philippe(output_path):
    driver = _make_driver()
    wait   = WebDriverWait(driver, 20)
    all_stores = {}

    def _store_key(s):
        return (s["Store Name"].lower(), s["Pincode"] or s["Phone"])

    def _add(stores):
        new = 0
        for s in stores:
            k = _store_key(s)
            if k not in all_stores:
                all_stores[k] = s
                new += 1
        return new

    try:
        print("[INFO] Opening Louis Philippe store locator...")
        driver.get(STORELOCATOR_URL)
        time.sleep(6)
        print(f"[INFO] Title: {driver.title}")

        dbg = driver.execute_script("""
            var inputs = document.querySelectorAll('input');
            var found = [];
            for (var i = 0; i < inputs.length; i++) {
                found.push(inputs[i].placeholder || '(no placeholder)');
            }
            return found;
        """)
        print(f"[DEBUG] All input placeholders on page: {dbg}")

        for ci, city in enumerate(MAJOR_CITIES):
            # ---- session health check ----
            if not _is_alive(driver):
                print(f"\n[WARN] Browser was closed at city {ci+1} ({city}). Saving partial results.")
                break

            print(f"[{ci+1}/{len(MAJOR_CITIES)}] {city}", end="", flush=True)

            try:
                search = _search_term(city)
                inp = _find_city_input(driver)
                _clear_and_type(driver, inp, search)

                # Click dropdown option — prefers match with city name
                clicked = _click_first_dropdown_option(driver, city=search)
                if clicked:
                    print(f"  [dropdown: {clicked[:40]}]", end="", flush=True)
                else:
                    # Fallback: Arrow Down + Enter
                    inp.send_keys(Keys.ARROW_DOWN)
                    time.sleep(0.4)
                    inp.send_keys(Keys.RETURN)

                _wait_for_stores(driver, timeout=5)
                count = _get_store_count(driver)

                stores = _scrape_visible_stores(driver, city)
                n = _add(stores)
                print(f"  {count} found / {len(stores)} parsed / {n} new  [total {len(all_stores)}]")

                # Intermediate save every 10 cities
                if (ci + 1) % 10 == 0:
                    _save_partial(all_stores, output_path)

            except WebDriverException as e:
                if "invalid session id" in str(e) or "no such session" in str(e):
                    print(f"\n[WARN] Session lost. Saving partial results.")
                    break
                print(f"  [ERR: {e}]")
            except Exception as e:
                print(f"  [ERR: {e}]")

    finally:
        try:
            driver.quit()
        except Exception:
            pass

    if not all_stores:
        raise RuntimeError(
            "No stores scraped.\n"
            "Check [DEBUG] line above — if the City/Area input placeholder is missing,\n"
            "the page structure has changed. Share this output to fix the selector."
        )

    df = pd.DataFrame(all_stores.values()).drop(columns=["City Searched"], errors="ignore")
    df = df.sort_values("Store Name").reset_index(drop=True)
    df.to_excel(output_path, index=False)
    print(f"\n[INFO] Saved {len(df)} stores -> {output_path}")
    return df


